<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/white"
        app:title="Rate &amp; Review"
        app:navigationIcon="@drawable/ic_back"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="24dp">

            <TextView android:id="@+id/tvOrderRef"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Order #1024" android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/text_primary" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="KFC — Kandy" android:textSize="15sp"
                android:textColor="@color/text_secondary" android:layout_marginBottom="28dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🍔 How was the food?" android:textSize="16sp"
                android:textStyle="bold" android:layout_marginBottom="8dp"/>

            <RatingBar android:id="@+id/ratingFood"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:numStars="5" android:stepSize="1"
                android:progressTint="@color/yellow"
                android:layout_marginBottom="24dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🚴 How was the delivery?" android:textSize="16sp"
                android:textStyle="bold" android:layout_marginBottom="8dp"/>

            <RatingBar android:id="@+id/ratingDelivery"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:numStars="5" android:stepSize="1"
                android:progressTint="@color/yellow"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Leave a comment (optional)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etComment"
                    android:layout_width="match_parent" android:layout_height="100dp"
                    android:gravity="top" android:inputType="textMultiLine"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitReview"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="Submit Review ⭐"
                app:backgroundTint="@color/orange_primary"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>